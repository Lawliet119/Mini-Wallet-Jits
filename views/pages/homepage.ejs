<main class="wallet-shell" data-app="mini-wallet">
  <header class="app-header">
    <div>
      <p class="eyebrow">Mini Wallet Console</p>
      <h1>JITS Mini Wallet</h1>
    </div>
    <div class="header-actions">
      <button class="ghost-btn" data-action="refreshAll" type="button">Refresh</button>
      <button class="danger-btn" data-action="clearSession" type="button">Clear Session</button>
    </div>
  </header>

  <section class="status-band">
    <div class="metric">
      <span>Role</span>
      <strong data-field="role">Guest</strong>
    </div>
    <div class="metric">
      <span>Phone</span>
      <strong data-field="phone">-</strong>
    </div>
    <div class="metric">
      <span>Balance</span>
      <strong data-field="balance">-</strong>
    </div>
    <div class="metric">
      <span>Pocket</span>
      <strong data-field="pocket">-</strong>
    </div>
  </section>

  <nav class="mode-tabs" aria-label="Mini wallet modes">
    <button class="mode-tab is-active" data-mode="customer" type="button">Customer</button>
    <button class="mode-tab" data-mode="officer" type="button">Officer</button>
    <button class="mode-tab" data-mode="transactions" type="button">Transactions</button>
    <button class="mode-tab" data-mode="config" type="button">Config</button>
  </nav>

  <section class="workspace-grid">
    <article class="panel" data-panel="customer">
      <div class="panel-head">
        <h2>Customer Access</h2>
        <span data-chip="customer">Signed out</span>
      </div>
      <div class="form-grid">
        <label>
          Phone
          <input data-input="customerPhone" value="0703900625" autocomplete="username">
        </label>
        <label>
          PIN
          <input data-input="customerPin" value="123456" type="password" autocomplete="current-password">
        </label>
        <label>
          Currency
          <input data-input="customerCurrency" value="VND">
        </label>
        <div class="button-row">
          <button data-action="customerLogin" type="button">Login</button>
          <button class="ghost-btn" data-action="customerRegister" type="button">Register</button>
        </div>
      </div>
    </article>

    <article class="panel" data-panel="customer">
      <div class="panel-head">
        <h2>P2P Transfer</h2>
        <span data-state="p2p">Ready</span>
      </div>
      <div class="form-grid">
        <label>
          Receiver Phone
          <input data-input="p2pReceiverPhone" value="0334760905">
        </label>
        <label>
          Amount
          <input data-input="p2pAmount" value="50000" inputmode="numeric">
        </label>
        <label class="span-2">
          Message
          <input data-input="p2pMessage" value="Chuyen tien thu">
        </label>
      </div>
      <div class="button-row">
        <button data-action="p2pRequest" type="button">Request</button>
        <button data-action="p2pConfirm" type="button">Confirm</button>
        <button data-action="p2pVerify" type="button">Verify</button>
      </div>
      <pre data-output="p2p"></pre>
    </article>

    <article class="panel" data-panel="customer">
      <div class="panel-head">
        <h2>Bill Payment</h2>
        <span data-state="bill">Ready</span>
      </div>
      <div class="form-grid">
        <label>
          Biller
          <select data-input="billerId"></select>
        </label>
        <label>
          Bill Code
          <input data-input="billCode" value="EVN001">
        </label>
      </div>
      <div class="button-row">
        <button data-action="loadBillers" type="button">Load Billers</button>
        <button data-action="billRequest" type="button">Inquiry</button>
        <button data-action="billConfirm" type="button">Confirm</button>
        <button data-action="billVerify" type="button">Pay</button>
      </div>
      <pre data-output="bill"></pre>
    </article>

    <article class="panel" data-panel="officer" hidden>
      <div class="panel-head">
        <h2>Officer Access</h2>
        <span data-chip="officer">Signed out</span>
      </div>
      <div class="form-grid">
        <label>
          Phone
          <input data-input="officerPhone" value="0900000000" autocomplete="username">
        </label>
        <label>
          PIN
          <input data-input="officerPin" value="123456" type="password" autocomplete="current-password">
        </label>
        <label>
          Name
          <input data-input="officerName" value="Operator">
        </label>
        <div class="button-row">
          <button data-action="officerLogin" type="button">Login</button>
          <button class="ghost-btn" data-action="officerRegister" type="button">Register</button>
        </div>
      </div>
    </article>

    <article class="panel" data-panel="officer" hidden>
      <div class="panel-head">
        <h2>Cash-In</h2>
        <span data-state="cashIn">Ready</span>
      </div>
      <div class="form-grid">
        <label>
          Customer Phone
          <input data-input="cashInCustomerPhone" value="0703900625">
        </label>
        <label>
          Amount
          <input data-input="cashInAmount" value="200000" inputmode="numeric">
        </label>
      </div>
      <div class="button-row">
        <button data-action="cashIn" type="button">Execute</button>
      </div>
      <pre data-output="cashIn"></pre>
    </article>

    <article class="panel wide-panel" data-panel="transactions" hidden>
      <div class="panel-head">
        <h2>Transaction History</h2>
        <span data-state="history">Ready</span>
      </div>
      <div class="button-row">
        <button data-action="loadHistory" type="button">Load History</button>
      </div>
      <div class="history-list" data-list="history"></div>
      <pre data-output="detail"></pre>
    </article>

    <article class="panel wide-panel" data-panel="config" hidden>
      <div class="panel-head">
        <h2>Service Config</h2>
        <span data-state="config">Officer only</span>
      </div>
      <div class="button-row">
        <button data-action="loadConfigServices" type="button">Load Services</button>
      </div>
      <div class="config-layout">
        <div class="service-list" data-list="services"></div>
        <div class="config-detail" data-list="configDetail"></div>
      </div>
    </article>
  </section>

  <aside class="event-console">
    <div class="panel-head">
      <h2>Run Log</h2>
      <span data-state="last">Idle</span>
    </div>
    <pre data-output="log"></pre>
  </aside>
</main>
